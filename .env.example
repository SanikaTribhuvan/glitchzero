# ═══════════════════════════════════════════════════════════════
#  GlitchZero v6 — Environment Configuration (PostgreSQL edition)
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────
PORT=5000

# ── Database ─────────────────────────────────────────────────────
# PostgreSQL connection string. Examples:
#
#  Neon (recommended for Render/Railway):
#    DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
#
#  Supabase:
#    DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
#
#  Railway:
#    DATABASE_URL=postgresql://postgres:[password]@containers-us-west-xx.railway.app:7xxx/railway
#
#  Local Docker:
#    DATABASE_URL=postgresql://postgres:postgres@localhost:5432/glitchzero
DATABASE_URL=

# ── Master API Key ───────────────────────────────────────────────
# Pre-seeded key that always exists on startup. Leave blank to disable.
MASTER_API_KEY=gz_master_change_me_in_production

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Use "*" to allow all (not recommended for production).
# Example: https://casas.yourdomain.com,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Agentic Mitigation / Self-Heal Webhook ───────────────────────
# GlitchZero fires a real POST to this URL when riskScore >= 96.
# Payload: { entityId, timestamp, riskScore, flagReason }
# Leave blank → uses internal echo endpoint (safe default for demos).
ROLLBACK_URL=

# ── Merkle Batch Size ────────────────────────────────────────────
# Number of anchors per Merkle commit. Default: 10.
MERKLE_BATCH_SIZE=10

# ── Blockchain (Polygon Amoy Testnet) ────────────────────────────
# BLOCKCHAIN_MODE=live  → real on-chain transactions
# BLOCKCHAIN_MODE=simulated (default) → deterministic SHA-256 simulation
BLOCKCHAIN_MODE=simulated

# Only required when BLOCKCHAIN_MODE=live:
POLYGON_PRIVATE_KEY=
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology/
MERKLE_CONTRACT_ADDRESS=
