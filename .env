#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────
PORT=5000

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://neondb_owner:npg_o6zdg8wtyxLN@ep-nameless-sound-a1k1u47r-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── Master API Key ───────────────────────────────────────────────
MASTER_API_KEY=gz_master_change_me_in_production

# ── CORS ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Agentic Mitigation / Self-Heal Webhook ───────────────────────
ROLLBACK_URL=

# ── Merkle Batch Size ────────────────────────────────────────────
MERKLE_BATCH_SIZE=10

# ── Blockchain (Polygon Amoy Testnet) ────────────────────────────
BLOCKCHAIN_MODE=simulated
POLYGON_PRIVATE_KEY=
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology/
MERKLE_CONTRACT_ADDRESS=